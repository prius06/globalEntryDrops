{
  "manifest_version": 3,
  "name": "Global Emtry Drops",
  "description": "Find global entry intervimm",
  "version": "1.0",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://ttp.cbp.dhs.gov/*"
  ]
}